<Page x:Class="REDConstruct.Views.RapoarteView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.com/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Raport Consum Materiale pe Obiectiv"
      Background="White">

    <Grid>
        <StackPanel Margin="20">
            <!-- Title -->
            <TextBlock Text="Raport 1: Consum Materiale pe Obiectiv" 
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#003366"/>

            <!-- Filter Panel -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="15" Margin="0,0,0,15" Background="#F9F9F9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Data Inceput -->
                    <TextBlock Text="Data Început:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <DatePicker Grid.Column="1" SelectedDate="{Binding DataInceput}" 
                                SelectedDateFormat="Short" Padding="8"/>

                    <!-- Data Sfarsit -->
                    <TextBlock Grid.Column="2" Text="Data Sfârșit:" VerticalAlignment="Center" Margin="20,0,10,0" FontWeight="Bold"/>
                    <DatePicker Grid.Column="3" SelectedDate="{Binding DataSfarsit}" 
                                SelectedDateFormat="Short" Padding="8"/>

                    <!-- Obiectiv ComboBox -->
                    <TextBlock Grid.Column="4" Text="Obiectiv:" VerticalAlignment="Center" Margin="20,0,10,0" FontWeight="Bold"/>
                    <ComboBox Grid.Column="5" ItemsSource="{Binding Obiective}" 
                              SelectedItem="{Binding ObiectivSelectat}" Padding="8"/>

                    <!-- Filter Button -->
                    <Button Grid.Column="7" Content="Filtrează" Command="{Binding FiltreazaCommand}"
                            Background="#0066CC" Foreground="White" Padding="15,8" 
                            FontWeight="Bold" Cursor="Hand" Margin="20,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0052A3"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Data Grid -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15">
                <DataGrid ItemsSource="{Binding RaportData}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" 
                          Background="White" AlternatingRowBackground="#F5F5F5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Obiectiv" Binding="{Binding Obiectiv}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Material" Binding="{Binding Material}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Cantitate" Binding="{Binding Cantitate}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Cost" Binding="{Binding Cost, StringFormat='{0:N2}'}" 
                                          Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Data Calcul" Binding="{Binding DataCalcul, StringFormat='dd.MM.yyyy'}" 
                                          Width="120" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Export Button -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="📊 Export Excel" Command="{Binding ExporterExcelCommand}"
                        Background="#28A745" Foreground="White" Padding="20,10" 
                        FontWeight="Bold" FontSize="12" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#218838"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
