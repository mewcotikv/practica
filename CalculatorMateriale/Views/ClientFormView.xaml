<UserControl x:Class="CalculatorMateriale.Views.ClientFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CalculatorMateriale.Views"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="600">
    
    <Border Background="White" CornerRadius="8" Padding="20" Margin="20">
        <StackPanel>
            <!-- Form Title -->
            <TextBlock Text="Formular Client" 
                       Style="{StaticResource TitleTextBlockStyle}"
                       Foreground="#C0392B"
                       Margin="0,0,0,20"/>

            <!-- Nume Field -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Denumire Companie *" 
                           Style="{StaticResource LabelTextBlockStyle}"/>
                <TextBox x:Name="NumeTextBox"
                         Style="{StaticResource DefaultTextBoxStyle}"
                         Height="36"
                         VerticalContentAlignment="Center"
                         Margin="0,5,0,0"/>
                <TextBlock x:Name="NumeErrorLabel"
                           Style="{StaticResource ErrorTextBlockStyle}"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- CUI Field -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="CUI (Cod Fiscal) *" 
                           Style="{StaticResource LabelTextBlockStyle}"/>
                <TextBox x:Name="CUITextBox"
                         Style="{StaticResource DefaultTextBoxStyle}"
                         Height="36"
                         VerticalContentAlignment="Center"
                         Margin="0,5,0,0"/>
                <TextBlock x:Name="CUIErrorLabel"
                           Style="{StaticResource ErrorTextBlockStyle}"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Adresa Field -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Adresa" 
                           Style="{StaticResource LabelTextBlockStyle}"/>
                <TextBox x:Name="AdresaTextBox"
                         Style="{StaticResource DefaultTextBoxStyle}"
                         Height="36"
                         VerticalContentAlignment="Center"
                         Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Localitate Field -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Localitate / Oraș" 
                           Style="{StaticResource LabelTextBlockStyle}"/>
                <TextBox x:Name="LocalitateTextBox"
                         Style="{StaticResource DefaultTextBoxStyle}"
                         Height="36"
                         VerticalContentAlignment="Center"
                         Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Cod Postal Field -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Cod Poștal" 
                           Style="{StaticResource LabelTextBlockStyle}"/>
                <TextBox x:Name="CodPostalTextBox"
                         Style="{StaticResource DefaultTextBoxStyle}"
                         Height="36"
                         VerticalContentAlignment="Center"
                         Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Telefon Field -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Telefon" 
                           Style="{StaticResource LabelTextBlockStyle}"/>
                <TextBox x:Name="TelefonTextBox"
                         Style="{StaticResource DefaultTextBoxStyle}"
                         Height="36"
                         VerticalContentAlignment="Center"
                         Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Email Field -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Email" 
                           Style="{StaticResource LabelTextBlockStyle}"/>
                <TextBox x:Name="EmailTextBox"
                         Style="{StaticResource DefaultTextBoxStyle}"
                         Height="36"
                         VerticalContentAlignment="Center"
                         Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Separator Line -->
            <Border Height="1" Background="#E0E0E0" Margin="0,0,0,20"/>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="AnulearButton"
                        Content="❌ Anulează" 
                        Style="{StaticResource OutlineButtonStyle}"
                        Padding="15,10"
                        Margin="0,0,10,0"
                        Width="120"/>
                <Button x:Name="SalveazaButton"
                        Content="💾 Salvează" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="15,10"
                        Width="120"
                        Click="SalveazaButton_Click"/>
            </StackPanel>

            <!-- Info Text -->
            <TextBlock Text="* Câmpuri obligatorii" 
                       FontSize="11"
                       Foreground="#999999"
                       Margin="0,15,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
